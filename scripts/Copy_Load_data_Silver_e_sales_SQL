-- Truncating table: Silver.e_sales_data
Truncate table silver.e_sales_data;
-- or
drop table if exists silver.e_Sales_data;

-- CREATE TABLE E_SALES_dATA
create table silver.e_Sales_data(
	id int ,
	Customer_Name varchar(50),
	Order_ID varchar(50),
	Order_Date text,
	Product text,
	Category text,
	Quantity text,
	Price varchar(20),
	Payment_Method varchar(50),
	Status text,
	Total text
);

-- Extract data from directly from local file via url
copy silver.e_Sales_data from 'C:\Users\ACER\Desktop\ETL_SQL\Data\ecommerce_sales_data.csv' with
(
	header true,
	format csv,
	delimiter ','
);

-- -- modify or change data type of order_date
-- Alter table silver.e_sales_data
